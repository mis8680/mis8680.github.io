<footer class="mx-auto w-full max-w-6xl px-6 pb-10">
	<div
		class="flex flex-col gap-3 rounded-[1.5rem] border border-[color:var(--color-border)] bg-[color:var(--surface-card)] px-5 py-4 sm:flex-row sm:items-center sm:justify-between"
		style="box-shadow: var(--shadow-nav);"
	>
		<p class="text-sm font-medium text-[color:var(--color-text)]">
			© <time data-footer-year datetime={String(new Date().getFullYear())}>{new Date().getFullYear()}</time> Insu Mun
		</p>
		<p class="text-sm text-[color:var(--color-muted-text)]">
			Built with
			<a
				href="https://astro.build"
				target="_blank"
				rel="noreferrer"
				class="font-medium text-[color:var(--color-text)] transition hover:text-[color:var(--color-accent)]"
			>
				Astro
			</a>.
		</p>
	</div>
</footer>

<script is:inline>
	const currentYear = String(new Date().getFullYear());

	document.querySelectorAll('[data-footer-year]').forEach((yearElement) => {
		if (!(yearElement instanceof HTMLTimeElement)) {
			return;
		}

		yearElement.dateTime = currentYear;
		yearElement.textContent = currentYear;
	});
</script>
