---
const notes = [
	{
		label: 'Working style',
		text: 'Start with the big product move, then tighten the system and the implementation until the page feels inevitable.',
	},
	{
		label: 'What I care about',
		text: 'Clarity, motion restraint, and interfaces with enough personality to feel memorable without getting noisy.',
	},
];
---

<section
	id="about"
	class="relative isolate overflow-hidden rounded-[2.5rem] border border-[color:var(--color-border)] bg-[color:color-mix(in_srgb,var(--color-surface)_74%,transparent)] px-6 py-8 shadow-[0_28px_90px_rgba(4,19,24,0.2)] scroll-mt-28 sm:px-8 sm:py-10 lg:px-10 lg:py-12"
	aria-labelledby="about-heading"
>
	<div aria-hidden="true" class="absolute inset-0">
		<div class="absolute inset-0 bg-[linear-gradient(135deg,color-mix(in_srgb,var(--color-surface)_94%,transparent),color-mix(in_srgb,var(--color-background)_88%,transparent))]"></div>
		<div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_22%,rgba(94,234,212,0.1),transparent_26%),radial-gradient(circle_at_82%_18%,rgba(45,212,191,0.08),transparent_22%)]"></div>
		<div class="absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,transparent,rgba(94,234,212,0.42),transparent)]"></div>
		<div class="absolute inset-y-10 right-[34%] hidden w-px bg-[linear-gradient(180deg,transparent,rgba(148,163,184,0.16),transparent)] lg:block"></div>
	</div>

	<div class="relative z-10 grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(18rem,0.72fr)] lg:items-center">
		<div class="space-y-6">
			<div class="space-y-4">
				<p class="text-xs font-semibold uppercase tracking-[0.32em] text-[color:var(--color-accent)]">
					About
				</p>
				<h2
					id="about-heading"
					class="max-w-3xl text-3xl font-semibold tracking-[-0.04em] text-[color:var(--color-text)] sm:text-4xl lg:text-5xl"
				>
					I like shaping product direction and front-end craft in the same pass.
				</h2>
				<p class="max-w-2xl text-sm leading-7 text-[color:var(--color-text)] sm:text-base">
					My process usually starts with finding the clearest story in the room: what matters,
					where attention should go, and which details earn their keep.
				</p>
				<p class="max-w-2xl text-sm leading-7 text-[color:var(--color-muted-text)] sm:text-base">
					From there I build the system, tune the motion, and keep refining until the final
					interface feels considered in both the design file and the shipped code.
				</p>
			</div>

			<div class="grid gap-3 sm:grid-cols-2">
				{
					notes.map(({ label, text }) => (
						<div class="rounded-[1.4rem] border border-[color:var(--color-border)] bg-[color:color-mix(in_srgb,var(--color-background)_18%,transparent)] px-4 py-4">
							<p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[color:var(--color-accent)]">
								{label}
							</p>
							<p class="mt-3 text-sm leading-7 text-[color:var(--color-text)]">{text}</p>
						</div>
					))
				}
			</div>
		</div>

		<div aria-hidden="true" class="flex justify-center lg:justify-end">
			<div class="relative aspect-square w-full max-w-[20rem]">
				<div class="absolute inset-0 rounded-full border border-[color:color-mix(in_srgb,var(--color-accent)_28%,var(--color-border))] bg-[radial-gradient(circle_at_30%_28%,rgba(94,234,212,0.18),transparent_30%),linear-gradient(180deg,color-mix(in_srgb,var(--color-background)_22%,transparent),color-mix(in_srgb,var(--color-surface)_84%,transparent))] shadow-[0_24px_80px_rgba(4,19,24,0.24)]"></div>
				<div class="absolute inset-4 rounded-full border border-[color:rgba(255,255,255,0.08)]"></div>
				<div class="absolute inset-10 rounded-full border border-[color:var(--color-border)] bg-[color:color-mix(in_srgb,var(--color-background)_20%,transparent)] backdrop-blur-sm"></div>
				<div class="absolute inset-0 flex items-center justify-center">
					<div class="rounded-full border border-[color:var(--color-border)] bg-[color:color-mix(in_srgb,var(--color-surface)_82%,transparent)] px-10 py-12 text-center shadow-[0_18px_50px_rgba(4,19,24,0.18)]">
						<p class="text-[0.68rem] font-semibold uppercase tracking-[0.32em] text-[color:var(--color-accent)]">
							Photo
						</p>
						<p class="mt-4 text-5xl font-semibold tracking-[-0.06em] text-[color:var(--color-text)] sm:text-6xl">
							IM
						</p>
						<p class="mt-4 text-sm leading-6 text-[color:var(--color-muted-text)]">
							Styled portrait placeholder
						</p>
					</div>
				</div>
				<div class="absolute bottom-4 right-2 rounded-full border border-[color:var(--color-border)] bg-[color:color-mix(in_srgb,var(--color-background)_24%,transparent)] px-4 py-2 text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[color:var(--color-accent)]">
					Ready for photo
				</div>
			</div>
		</div>
	</div>
</section>
