---
import { contactLinks, type ContactLinkKey } from '../data/contactLinks';

const contactActionOrder: ContactLinkKey[] = ['email', 'github', 'linkedin'];
const contactActions = contactActionOrder.map((linkKey) => ({
	...contactLinks[linkKey],
	featured: linkKey === 'email',
}));
---

<section
	id="contact"
	class="relative isolate overflow-hidden rounded-[2.5rem] border border-[color:var(--color-border)] px-6 py-8 scroll-mt-28 sm:px-8 sm:py-10 lg:px-10 lg:py-12"
	style="background-color: var(--surface-section); box-shadow: var(--shadow-section);"
	data-animate="fade-up"
	aria-labelledby="contact-heading"
>
	<div aria-hidden="true" class="absolute inset-0">
		<div class="absolute inset-0" style="background-image: var(--gradient-section);"></div>
		<div
			class="absolute inset-0"
			style="background-image: radial-gradient(circle at 16% 18%, var(--accent-wash-strong), transparent 24%), radial-gradient(circle at 84% 16%, var(--accent-glow-soft), transparent 22%);"
		></div>
		<div class="absolute inset-x-0 top-0 h-px" style="background-image: linear-gradient(90deg, transparent, var(--divider-accent), transparent);"></div>
		<div class="absolute inset-y-10 right-[34%] hidden w-px lg:block" style="background-image: linear-gradient(180deg, transparent, var(--line-soft), transparent);"></div>
	</div>

	<div class="relative z-10 grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(19rem,0.82fr)] lg:items-end">
		<div class="space-y-5">
			<p class="text-xs font-semibold uppercase tracking-[0.32em] text-[color:var(--color-accent)]">
				Contact
			</p>
			<h2
				id="contact-heading"
				class="max-w-3xl text-3xl font-semibold tracking-[-0.04em] text-[color:var(--color-text)] sm:text-4xl lg:text-5xl"
			>
				Let&apos;s make the next interface feel clear, sharp, and ready to ship.
			</h2>
			<p class="max-w-2xl text-sm leading-7 text-[color:var(--color-text)] sm:text-base">
				If you want to talk through product direction, front-end craft, or a collaboration
				that needs both, I&apos;m easy to reach.
			</p>
			<p class="max-w-2xl text-sm leading-7 text-[color:var(--color-muted-text)] sm:text-base">
				Email is the fastest path. GitHub and LinkedIn are here if you want to see work,
				context, or connect there first.
			</p>
		</div>

		<div class="rounded-[2rem] border border-[color:var(--border-accent-panel)] bg-[color:var(--surface-elevated)] p-5 backdrop-blur-sm sm:p-6">
			<div class="space-y-4">
				<p class="text-xs font-semibold uppercase tracking-[0.32em] text-[color:var(--color-accent)]">
					Reach out
				</p>

				<div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
					{
						contactActions.map(({ href, label, detail, external, featured }) => (
							<a
								href={href}
								target={external ? '_blank' : undefined}
								rel={external ? 'noreferrer' : undefined}
								class:list={[
									'group flex min-h-28 flex-col justify-between rounded-[1.5rem] border px-4 py-4 text-left transition duration-300 ease-out hover:-translate-y-0.5',
									featured
										? 'border-[color:var(--color-accent)] bg-[color:var(--color-accent)] text-[color:var(--color-background)] hover:border-[color:var(--color-accent-hover)] hover:bg-[color:var(--color-accent-hover)]'
										: 'border-[color:var(--color-border)] bg-[color:var(--surface-card)] text-[color:var(--color-text)] hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]',
								]}
							>
								<div class="flex items-center justify-between gap-3">
									<span class="text-sm font-semibold">{label}</span>
									<span
										class:list={[
											'rounded-full border px-2.5 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.24em]',
											featured
												? 'border-[color:var(--overlay-tone-strong)] bg-[color:var(--overlay-tone)] text-[color:var(--color-background)]'
												: 'border-[color:var(--color-border)] bg-[color:var(--surface-subtle)] text-[color:var(--color-muted-text)] group-hover:text-[color:var(--color-accent)]',
										]}
									>
										{external ? 'Open' : 'Send'}
									</span>
								</div>

								<p
									class:list={[
										'mt-4 text-sm leading-6',
										featured
											? 'text-[color:var(--color-background)]'
											: 'text-[color:var(--color-muted-text)] group-hover:text-[color:var(--color-text)]',
									]}
								>
									{detail}
								</p>
							</a>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>
