---
interface Props {
	title: string;
	description: string;
	tags: string[];
	href: string;
	featured?: boolean;
}

const { title, description, tags, href, featured = false } = Astro.props;
---

<a
	href={href}
	aria-label={`View project: ${title}`}
	class:list={[
		'group relative flex h-full overflow-hidden rounded-[1.75rem] border border-[color:var(--color-border)] bg-[color:var(--surface-card)] text-left transition duration-300 ease-out hover:-translate-y-1 hover:border-[color:var(--border-accent-hover)] hover:[box-shadow:var(--shadow-card-hover)] focus-visible:-translate-y-1 focus-visible:border-[color:var(--border-accent-hover)]',
		featured ? 'min-h-[26rem] p-6 sm:min-h-[31rem] sm:p-10' : 'min-h-[14rem] p-5 sm:min-h-[15rem] sm:p-6',
	]}
>
	<div
		aria-hidden="true"
		class:list={[
			'absolute inset-0 transition duration-300 ease-out',
			featured ? 'bg-[image:var(--gradient-card-featured)]' : 'bg-[image:var(--gradient-card)] group-hover:bg-[image:var(--gradient-card-hover)]',
		]}
	></div>
	<div
		aria-hidden="true"
		class:list={[
			'absolute inset-0 transition duration-300 ease-out',
			featured
				? 'bg-[image:radial-gradient(circle_at_20%_18%,var(--accent-wash-strong),transparent_30%),radial-gradient(circle_at_82%_18%,var(--accent-wash-soft),transparent_25%),linear-gradient(180deg,transparent,var(--overlay-tone-strong))]'
				: 'bg-[image:radial-gradient(circle_at_80%_12%,var(--accent-wash-soft),transparent_26%),linear-gradient(180deg,transparent,var(--overlay-tone))] group-hover:bg-[image:radial-gradient(circle_at_78%_10%,var(--accent-wash-strong),transparent_30%),linear-gradient(180deg,transparent,var(--overlay-tone))]',
		]}
	></div>

	<div class="relative z-10 flex h-full flex-col justify-between gap-6 sm:gap-8">
		<div class="space-y-4 sm:space-y-5">
			<div class="flex items-start justify-between gap-4">
				<span
					class:list={[
						'inline-flex w-fit items-center gap-2 rounded-full border px-3 py-1.5 text-[0.68rem] font-semibold uppercase tracking-[0.28em]',
						featured
							? 'border-[color:var(--border-accent-soft)] bg-[color:var(--surface-subtle)] text-[color:var(--color-accent)]'
							: 'border-[color:var(--color-border)] bg-[color:var(--surface-subtle)] text-[color:var(--color-muted-text)] group-hover:text-[color:var(--color-accent)]',
					]}
				>
					<span
						class:list={[
							'h-2 w-2 rounded-full transition duration-300',
							featured
								? 'bg-[color:var(--color-accent)] shadow-[0_0_18px_var(--accent-dot-shadow)]'
								: 'bg-[color:color-mix(in_srgb,var(--color-muted-text)_70%,transparent)] group-hover:bg-[color:var(--color-accent)]',
						]}
					></span>
					{featured ? 'Featured project' : 'Selected work'}
				</span>

				<span
					class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-[color:var(--color-border)] bg-[color:var(--surface-soft)] text-[color:var(--color-text)] transition duration-300 group-hover:border-[color:var(--color-accent)] group-hover:text-[color:var(--color-accent)]"
				>
					<svg
						class="h-5 w-5 transition duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="1.8"
						aria-hidden="true"
					>
						<path d="M7 17 17 7" />
						<path d="M9 7h8v8" />
					</svg>
				</span>
			</div>

			<div class="space-y-3">
				<h3
					class:list={[
						'max-w-[18ch] font-semibold tracking-[-0.03em] text-[color:var(--color-text)]',
						featured ? 'text-3xl sm:text-4xl' : 'text-2xl',
					]}
				>
					{title}
				</h3>
				<p
					class:list={[
						'max-w-[34rem] leading-7 text-[color:var(--color-muted-text)]',
						featured ? 'text-base sm:text-lg sm:leading-8' : 'text-sm sm:text-base',
					]}
				>
					{description}
				</p>
			</div>
		</div>

		<div class="space-y-4 sm:space-y-5">
			<ul class="flex flex-wrap gap-2" aria-label="Project tags">
				{
					tags.map((tag) => (
						<li class="rounded-full border border-[color:var(--color-border)] bg-[color:var(--surface-tag)] px-3 py-1.5 text-xs font-medium uppercase tracking-[0.2em] text-[color:var(--color-text)]">
							{tag}
						</li>
					))
				}
			</ul>

			<div class="flex items-center justify-between gap-4 border-t border-[color:var(--color-border)] pt-3 sm:pt-4">
				<p class="text-sm font-medium text-[color:var(--color-text)]">
					{featured ? 'See the redesign direction' : 'Explore the project angle'}
				</p>
				<p class="text-sm font-semibold text-[color:var(--color-accent)] transition duration-300 group-hover:translate-x-1">
					Learn more
				</p>
			</div>
		</div>
	</div>
</a>
